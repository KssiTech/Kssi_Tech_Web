# KSSI TECH — Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# SUPABASE CONFIGURATION (backend à brancher plus tard)
# =============================================================================
# Obtenir depuis : https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# =============================================================================
# ANTHROPIC API (optionnel — active les modèles Claude Pro / Claude Fast dans l'assistant IA)
# =============================================================================
# Obtenir depuis : https://console.anthropic.com/account/keys
# ATTENTION : clé exposée côté client (usage interne uniquement, ne pas déployer publiquement)
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Environment: development | production
NODE_ENV=development

# Application URL (utilisée pour les redirections OAuth et les URLs absolues)
# Development: http://localhost:5173
# Production: https://kssi-tech.com
VITE_APP_URL=http://localhost:5173
